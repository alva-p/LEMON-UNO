# .env.example - template for environment variables
# Copy this file to .env and fill values. NEVER commit real secrets.

# Private key for deployment (testnet account). Use a test account for testnet.
PRIVATE_KEY=

# Dev wallet (fee receiver)
DEV_WALLET=

# RPC endpoints
# Example: Alchemy / Infura / BlockPI / public RPC
ETH_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Mainnet RPC (only for production)
ETH_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Token addresses (testnet or mainnet per network)
USDT_ADDRESS_SEPOLIA=
USDC_ADDRESS_SEPOLIA=
USDT_ADDRESS_BASE_SEPOLIA=
USDC_ADDRESS_BASE_SEPOLIA=

# After deploying, populate contract addresses (optional)
CONTRACT_ADDRESS_SEPOLIA=
CONTRACT_ADDRESS_BASE_SEPOLIA=
CONTRACT_ADDRESS_MAINNET=

# Optional API keys
ALCHEMY_KEY=
INFURA_KEY=

# Frontend origin (for CORS or deeplinks)
FRONTEND_ORIGIN=

# Chain IDs (optional hints)
ETH_SEPOLIA_CHAIN_ID=11155111
BASE_SEPOLIA_CHAIN_ID=84531

# Notes:
# - Fill this file with your values and keep `.env` private.
# - For local testing you can use Anvil's default key (example in repo), but never use that key on public networks.
